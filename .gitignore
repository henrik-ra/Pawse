# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Fitbit secrets & tokens — never commit these
devices/fitbit/fitbit_tokens.json
devices/fitbit/.env

# Google Health secrets & tokens — never commit these
devices/google_health/google_tokens.json
devices/google_health/.env
devices/google_health/google_health_cache.json
.env

# Calendar cache — contains real meeting titles; commit only the .sample file
data/calendar_cache.json

# Data / media (keep small sample JSON, ignore heavy recordings)
voice-analysis/**/recordings/
voice-analysis/**/*.mp4
voice-analysis/**/*.wav
*.mov

# Pawse media analysis — local-only derived signals, watcher state, dropped media
data/media_signals.json
data/.media_state.json
data/recordings/*
!data/recordings/README.md

# WorkIQ calendar exports (transient, may contain personal meeting data)
data/_workiq_*.json

# Xiaomi watch — local Gadgetbridge database export (personal biometric data)
data/gadgetbridge-db/

# FER ONNX models (auto-downloaded on first run, ~36 MB)
voice-analysis/face_analysis/models/

# OS / editor
.DS_Store
.idea/
*.log
