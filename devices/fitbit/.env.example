# Fitbit API credentials (from https://dev.fitbit.com/apps)
# Copy this file to ".env" OR set them as environment variables before running
# the one-time login script (devices/fitbit/fitbit_auth.py).
#
# PowerShell:
#   $env:FITBIT_CLIENT_ID = "PASTE_CLIENT_ID"
#   $env:FITBIT_CLIENT_SECRET = "PASTE_CLIENT_SECRET"

FITBIT_CLIENT_ID=PASTE_CLIENT_ID
FITBIT_CLIENT_SECRET=PASTE_CLIENT_SECRET
