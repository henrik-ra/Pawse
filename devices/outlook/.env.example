# Microsoft Entra ID (Azure AD) credentials for Pawse calendar access.
# Copy this to .env and fill in your values.
#
# Register an app at https://entra.microsoft.com → App registrations
# - Supported account types: Accounts in any organizational directory
# - Redirect URI (Web): http://localhost:8722/callback
# - API permissions (delegated): User.Read, Calendars.Read, Calendars.ReadWrite,
#   Mail.ReadWrite, offline_access

MS_CLIENT_ID=your-client-id-here
MS_CLIENT_SECRET=your-client-secret-here
