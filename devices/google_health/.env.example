# Google Health API credentials (from Google Cloud Console -> OAuth client)
# Copy this file to ".env" OR set them as environment variables before running
# the one-time login script (devices/google_health/google_auth.py).
#
# PowerShell:
#   $env:GOOGLE_CLIENT_ID = "PASTE_CLIENT_ID.apps.googleusercontent.com"
#   $env:GOOGLE_CLIENT_SECRET = "PASTE_CLIENT_SECRET"

GOOGLE_CLIENT_ID=PASTE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=PASTE_CLIENT_SECRET
